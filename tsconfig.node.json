{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "src/mcp/**/*.ts",
    "electron.vite.config.ts",
    // refresh-repaint-integration-test-v1: the end-to-end integration test
    // (src/main/generative/refreshRepaintIntegration.test.ts) drives both the
    // main-side dispatcher/resolver/registration AND the renderer-PURE
    // `applyDataModel` (no DOM/React; imports only a src/shared type). cosmos
    // typechecks the two process trees as mutually-exclusive composite projects,
    // so that one cross-tree value import would otherwise be TS6307 ("not in the
    // file list"). Listing the single renderer-pure file the test needs lets it
    // typecheck without loosening the boundary to all of src/renderer.
    "src/renderer/generative/dataModelApply.ts"
  ]
}
