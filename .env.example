# cosmos local environment. Copy to `.env` (gitignored) and fill in.

# Public Slack app client_id for the read-only Slack integration (PKCE public
# client — no client secret is used). Create a Slack app, add the read-only
# scopes (channels:read, channels:history, users:read + user scope search:read),
# allowlist redirect URLs http://127.0.0.1:{7421,7422,7423}/callback, then put
# its Client ID here. With this unset, the Slack panel stays "not configured".
COSMOS_SLACK_CLIENT_ID=

# Atlassian OAuth 2.0 (3LO) app for the read-only Jira + Confluence integrations.
# Create one "OAuth 2.0 integration" app in the Atlassian developer console; add
# the Jira (read:jira-work, read:jira-user) and Confluence (read:confluence-content.all,
# read:confluence-space.summary, search:confluence) read scopes; allowlist callback
# http://127.0.0.1:7421/callback; copy its Client ID + Secret from Settings here.
# Atlassian Cloud 3LO is a confidential client, so the secret IS required (the
# secret stays in the main process only, never logged or sent off-process). With
# these unset, the Jira/Confluence panels stay "not configured".
COSMOS_ATLASSIAN_CLIENT_ID=
COSMOS_ATLASSIAN_CLIENT_SECRET=
