{
  "name": "cosmos",
  "productName": "cosmos",
  "version": "0.0.1",
  "description": "Conductor-style Electron host app embedding Claude Code as its engine",
  "main": "out/main/index.js",
  "author": "cosmos",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run src/main/*.integration.test.ts src/main/**/*.integration.test.ts",
    "test:dom": "vitest run --config vitest.dom.config.ts",
    "test:dom:watch": "vitest --config vitest.dom.config.ts",
    "test:visual": "playwright test --config playwright.visual.config.ts",
    "test:e2e": "playwright test --config playwright.e2e.config.ts",
    "rebuild": "electron-rebuild -f -w node-pty",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@a2ui-sdk/react": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "docx-preview": "^0.3.7",
    "dompurify": "^3.4.10",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.17.0",
    "monaco-editor": "^0.55.1",
    "node-emoji": "^2.2.0",
    "node-pty": "^1.1.0",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-pdf": "^10.4.1",
    "simple-icons": "^16.23.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^42.3.2",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  }
}
